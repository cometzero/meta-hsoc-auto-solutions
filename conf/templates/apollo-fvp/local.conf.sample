#
# SPDX-License-Identifier: MIT
#

# Apollo FVP build configuration for a traditional TEMPLATECONF workflow.
RD_ASPEN_VARIANT = "cfg2"
MACHINE = "apollo-fvp"
PC_CPUS_COUNT_DEFAULT = "16"
ARM_FVP_EULA_ACCEPT = "1"

# Keep the traditional TEMPLATECONF build aligned with the kas baremetal
# environment. The demos image autoloads pfdi_misc, so firmware-side PFDI
# support must be enabled too.
PFDI_SUPPORT = "1"
PFDI_MONITOR_SUPPORT = "1"

# baremetal
TMPDIR = "${TOPDIR}/tmp_baremetal"
EXTRA_IMAGE_FEATURES:append = " baremetal"

# base
EXTRA_IMAGE_FEATURES:append = " allow-empty-password allow-root-login \
  empty-root-password post-install-logging ssh-server-openssh"
CORE_IMAGE_EXTRA_INSTALL:append = " ssh-pregen-hostkeys"
LICENSE_FLAGS_ACCEPTED:append = " \
  ${@oe.utils.vartrue('ARM_FVP_EULA_ACCEPT', 'Arm-FVP-EULA', '', d)}"
IMAGE_CLASSES += "testimage"

# build-capsule
BUILD_UEFI_CAPSULE = "1"

# cassini
CASSINI_GENERIC_ARM64_FILESYSTEM = "0"
DISTRO_FEATURES:remove = "cassini-security cassini-ota cassini-parsec"
DISTRO_FEATURES:append = " cassini-dev zephyr"
KERNEL_CLASSES:remove = "containers_kernelcfg_check"

# cassini-base
CONF_VERSION = "2"
PACKAGECONFIG:remove:pn-qemu-system-native = "gtk+ sdl"

# cassini-modsign
DISTRO_FEATURES:append = " modsign"

# demos
EXTRA_IMAGE_FEATURES:append = " demos"

# diskmon
BB_DISKMON_DIRS = "\
  STOPTASKS,${TMPDIR},1G,100K \
  STOPTASKS,${DL_DIR},1G,100K \
  STOPTASKS,${SSTATE_DIR},1G,100K \
  STOPTASKS,/tmp,100M,100K \
  HALT,${TMPDIR},100M,1K \
  HALT,${DL_DIR},100M,1K \
  HALT,${SSTATE_DIR},100M,1K \
  HALT,/tmp,10M,1K"

DISTRO ??= "auto-ad-nexios"
BBMULTICONFIG ?= ""
